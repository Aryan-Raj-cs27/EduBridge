# --------------------------------------------------
# Dependencies and package managers
# --------------------------------------------------
/node_modules/
/.pnp
.pnp.*

.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --------------------------------------------------
# Build output and framework artifacts
# --------------------------------------------------
/.next/
/out/
/build/
/dist/

# Runtime artifacts
/coverage/
/logs/*
!/logs/.gitkeep
/tmp/*
!/tmp/.gitkeep
/temp/

# Caches
.cache/
.turbo/

# --------------------------------------------------
# Environment variables and secrets
# --------------------------------------------------
# Ignore all env files by default
.env
.env.*

# Allow safe templates/examples to be committed
!.env.example
!.env*.example
!.env.template

# Common secret/certificate/key patterns
*.pem
*.key
*.p12
*.pfx
*.crt
*.csr

id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Service account and cloud credential files
*-credentials.json
*credentials*.json
service-account*.json

# --------------------------------------------------
# Logs and debug
# --------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# --------------------------------------------------
# OS and editor noise
# --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Local Copilot/agent context notes
.github/context/

.idea/
*.swp
*.swo

# --------------------------------------------------
# Language/tooling extras
# --------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# Optional local databases
*.sqlite
*.sqlite3
*.db

# Archives
*.zip
*.tar
*.gz
*.7z
*.rar

# Office docs (keep out of code repo unless explicitly needed)
*.pptx
*.docx

# --------------------------------------------------
# Local AI notes
# --------------------------------------------------
AI_WORK_SUMMARY.md
AI_WORK_LOG.md
AI_HANDOFF_*.md
